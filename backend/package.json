{
  "name": "finance-manager-server",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "sh -c '. .venv/bin/activate && python -m uvicorn finance_server.main:app --host 0.0.0.0 --port 8110 --reload'",
    "build": "sh -c 'python3 -m venv .venv && . .venv/bin/activate && pip install --upgrade pip && pip install -r requirements.txt'",
    "start": "sh -c '. .venv/bin/activate && python -m uvicorn finance_server.main:app --host 127.0.0.1 --port 8112'"
  }
}
