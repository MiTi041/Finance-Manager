# =============================================================================
# Finance Manager — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
# =============================================================================


# --- Hunter.io API Key (optional) --------------------------------------------
#
# Used to automatically resolve company logos for known transaction partners.
# Get a free API key at: https://hunter.io/api-keys
#
# If not set, logo resolution is skipped (no impact on core functionality).
HUNTER_LOGO_KEY=


# --- CORS (optional, defaults to allow all origins) --------------------------
#
# Comma-separated list of allowed origins for development.
# Example: CORS_ORIGINS=http://localhost:8113,http://localhost:5173
#
# When running the packaged app (Electron), CORS is not relevant since the
# frontend is served from the file system. This is only needed during
# development when frontend and backend run on different ports.
CORS_ORIGINS=


# --- FinTS Sync Settings (optional) ------------------------------------------

# Maximum number of days to look back when fetching transactions.
# Default: 36500 (~100 years, effectively unlimited)
FINTS_MAX_DAYS=36500

# Number of days for the initial sync when no local data exists yet.
# Default: 730 (~2 years)
FINTS_INITIAL_SYNC_DAYS=730

# In-memory transaction cache TTL in seconds (default: 120 = 2 min).
FINTS_TRANSACTIONS_CACHE_TTL_SECONDS=120

# Maximum entries in the transaction cache (default: 32).
FINTS_TRANSACTIONS_CACHE_MAX_ENTRIES=32


# --- Advanced: File Paths (optional) -----------------------------------------

# Custom path to the SQLite database file.
# Default: <app-data-dir>/db/state/finance.db
# FINANCE_DB_FILE=

# Custom path to the credentials encryption key file.
# Default: <app-data-dir>/db/state/.credentials.key
# FINANCE_CREDENTIALS_KEY_FILE=

# Custom path to the FinTS client session state file.
# Default: backend/state/.fints_state (development) or /tmp/ (Vercel)
# FINTS_STATE_FILE=


# --- Advanced: Deployment (optional) -----------------------------------------

# Set to "1" when running in Vercel serverless environment.
# Uses /tmp/ paths for state files (stateless deployment).
# VERCEL=1
